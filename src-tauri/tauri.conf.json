{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WorldRec",
  "version": "0.1.2",
  "identifier": "com.dekapurin.worldrec",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run build:sidecar && npm run dev",
    "beforeBuildCommand": "npm run build:sidecar && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WorldRec",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: https://*.vrchat.cloud https://*.vrchat.com",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/worldrec-ai"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
